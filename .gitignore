# =============================================================================
# RIPA – App mobile (Expo / React Native) – .gitignore pour le dépôt mobileapp
# =============================================================================

# Dépendances
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native (générés par EAS / prebuild, ne pas versionner en Expo managed)
ios/
android/
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# Debug / logs
npm-debug.*
yarn-debug.*
yarn-error.*
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Fichiers d'environnement (secrets, URLs de prod, etc.)
.env
.env.*
.env*.local
!.env.example

# macOS
.DS_Store
*.pem
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini

# Éditeurs / IDE
.idea/
.vscode/
*.swp
*.swo
*~

# TypeScript / build
*.tsbuildinfo
build/
*.generated.*

# Tests / couverture
coverage/
.nyc_output/
*.lcov

# Temporaires
tmp/
temp/
*.tmp
.cache/
